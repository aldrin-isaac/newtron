{
  "version": "1.0",
  "description": "2-node topology: switch1 + switch2 with 6 test hosts — pure wiring diagram, no pre-configured IPs/VRFs/services",
  "devices": {
    "switch1": {
      "steps": [
        {"url": "/configure-loopback"},
        {"url": "/set-device-metadata", "params": {"fields": {"hostname": "switch1", "bgp_asn": "65001", "type": "LeafRouter", "hwsku": "cisco-p200-32x100-vs", "docker_routing_config_mode": "unified", "frr_mgmt_framework_config": "true"}}},
        {"url": "/configure-bgp"},
        {"url": "/add-overlay-peer", "params": {"neighbor_ip": "10.0.0.2", "asn": 65002, "evpn": false}}
      ],
      "ports": {
        "Ethernet0": {"admin_status": "up", "mtu": "9100"},
        "Ethernet1": {"admin_status": "up", "mtu": "9100"},
        "Ethernet2": {"admin_status": "up", "mtu": "9100"},
        "Ethernet3": {"admin_status": "up", "mtu": "9100"},
        "Ethernet4": {"admin_status": "up", "mtu": "9100"},
        "Ethernet5": {"admin_status": "up", "mtu": "9100"}
      }
    },
    "switch2": {
      "steps": [
        {"url": "/configure-loopback"},
        {"url": "/set-device-metadata", "params": {"fields": {"hostname": "switch2", "bgp_asn": "65002", "type": "LeafRouter", "hwsku": "cisco-p200-32x100-vs", "docker_routing_config_mode": "unified", "frr_mgmt_framework_config": "true"}}},
        {"url": "/configure-bgp"},
        {"url": "/add-overlay-peer", "params": {"neighbor_ip": "10.0.0.1", "asn": 65001, "evpn": false}}
      ],
      "ports": {
        "Ethernet0": {"admin_status": "up", "mtu": "9100"},
        "Ethernet1": {"admin_status": "up", "mtu": "9100"},
        "Ethernet2": {"admin_status": "up", "mtu": "9100"},
        "Ethernet3": {"admin_status": "up", "mtu": "9100"},
        "Ethernet4": {"admin_status": "up", "mtu": "9100"},
        "Ethernet5": {"admin_status": "up", "mtu": "9100"}
      }
    },
    "host1": {},
    "host2": {},
    "host3": {},
    "host4": {},
    "host5": {},
    "host6": {}
  },
  "links": [
    {"a": "switch1:Ethernet0", "z": "switch2:Ethernet0"},
    {"a": "switch1:Ethernet1", "z": "host1:eth0"},
    {"a": "switch1:Ethernet2", "z": "host2:eth0"},
    {"a": "switch1:Ethernet3", "z": "host3:eth0"},
    {"a": "switch1:Ethernet4", "z": "switch2:Ethernet4"},
    {"a": "switch1:Ethernet5", "z": "switch2:Ethernet5"},
    {"a": "switch2:Ethernet1", "z": "host4:eth0"},
    {"a": "switch2:Ethernet2", "z": "host5:eth0"},
    {"a": "switch2:Ethernet3", "z": "host6:eth0"}
  ],
  "newtlab": {
    "link_port_base": 10000,
    "console_port_base": 12000,
    "ssh_port_base": 13000
  }
}
