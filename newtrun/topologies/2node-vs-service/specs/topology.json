{
  "version": "1.0",
  "description": "2-node sonic-vs service topology: switch1 + switch2 with 8 test hosts — Force10-S6000 stride-4 ports",
  "devices": {
    "switch1": {
      "steps": [
        {"url": "/configure-loopback"},
        {"url": "/set-device-metadata", "params": {"fields": {"hostname": "switch1", "bgp_asn": "65001", "type": "LeafRouter", "hwsku": "Force10-S6000", "docker_routing_config_mode": "unified", "frr_mgmt_framework_config": "true"}}},
        {"url": "/setup-vtep", "params": {"source_ip": "10.0.0.1"}},
        {"url": "/configure-bgp"},
        {"url": "/interface/Ethernet0/apply-service", "params": {"service": "transit", "ip_address": "10.1.0.0/31", "peer_as": 65002}},
        {"url": "/interface/Ethernet4/apply-service", "params": {"service": "local-irb", "ip_address": "10.100.1.1/24"}},
        {"url": "/interface/Ethernet8/apply-service", "params": {"service": "local-bridge"}},
        {"url": "/interface/Ethernet12/apply-service", "params": {"service": "l2-extend"}},
        {"url": "/interface/Ethernet16/apply-service", "params": {"service": "overlay-irb-a"}}
      ],
      "ports": {
        "Ethernet0": {"admin_status": "up", "mtu": "9100"},
        "Ethernet4": {"admin_status": "up", "mtu": "9100"},
        "Ethernet8": {"admin_status": "up", "mtu": "9100"},
        "Ethernet12": {"admin_status": "up", "mtu": "9100"},
        "Ethernet16": {"admin_status": "up", "mtu": "9100"},
        "Ethernet20": {"admin_status": "up", "mtu": "9100"}
      }
    },
    "switch2": {
      "steps": [
        {"url": "/configure-loopback"},
        {"url": "/set-device-metadata", "params": {"fields": {"hostname": "switch2", "bgp_asn": "65002", "type": "LeafRouter", "hwsku": "Force10-S6000", "docker_routing_config_mode": "unified", "frr_mgmt_framework_config": "true"}}},
        {"url": "/setup-vtep", "params": {"source_ip": "10.0.0.2"}},
        {"url": "/configure-bgp"},
        {"url": "/interface/Ethernet0/apply-service", "params": {"service": "transit", "ip_address": "10.1.0.1/31", "peer_as": 65001}},
        {"url": "/interface/Ethernet4/apply-service", "params": {"service": "local-irb", "ip_address": "10.100.1.1/24"}},
        {"url": "/interface/Ethernet8/apply-service", "params": {"service": "local-bridge"}},
        {"url": "/interface/Ethernet12/apply-service", "params": {"service": "l2-extend"}},
        {"url": "/interface/Ethernet16/apply-service", "params": {"service": "overlay-irb-b"}}
      ],
      "ports": {
        "Ethernet0": {"admin_status": "up", "mtu": "9100"},
        "Ethernet4": {"admin_status": "up", "mtu": "9100"},
        "Ethernet8": {"admin_status": "up", "mtu": "9100"},
        "Ethernet12": {"admin_status": "up", "mtu": "9100"},
        "Ethernet16": {"admin_status": "up", "mtu": "9100"},
        "Ethernet20": {"admin_status": "up", "mtu": "9100"}
      }
    },
    "host1": {},
    "host2": {},
    "host3": {},
    "host4": {},
    "host5": {},
    "host6": {},
    "host7": {},
    "host8": {}
  },
  "links": [
    {"a": "switch1:Ethernet0", "z": "switch2:Ethernet0"},
    {"a": "switch1:Ethernet4", "z": "host1:eth0"},
    {"a": "switch1:Ethernet8", "z": "host2:eth0"},
    {"a": "switch1:Ethernet12", "z": "host3:eth0"},
    {"a": "switch1:Ethernet16", "z": "host7:eth0"},
    {"a": "switch1:Ethernet20", "z": "switch2:Ethernet20"},
    {"a": "switch2:Ethernet4", "z": "host4:eth0"},
    {"a": "switch2:Ethernet8", "z": "host5:eth0"},
    {"a": "switch2:Ethernet12", "z": "host6:eth0"},
    {"a": "switch2:Ethernet16", "z": "host8:eth0"}
  ],
  "newtlab": {
    "link_port_base": 10000,
    "console_port_base": 12000,
    "ssh_port_base": 13000
  }
}
