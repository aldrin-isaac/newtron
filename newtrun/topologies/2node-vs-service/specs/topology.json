{
  "version": "1.0",
  "description": "2-node sonic-vs service topology: switch1 + switch2 with 8 test hosts — Force10-S6000 stride-4 ports",
  "devices": {
    "switch1": {
      "interfaces": {
        "Ethernet0": { "link": "switch2:Ethernet0", "service": "transit", "ip": "10.1.0.0/31" },
        "Ethernet4": { "link": "host1:eth0", "service": "local-irb", "ip": "10.100.1.1/24" },
        "Ethernet8": { "link": "host2:eth0", "service": "local-bridge" },
        "Ethernet12": { "link": "host3:eth0", "service": "l2-extend" },
        "Ethernet16": { "link": "host7:eth0", "service": "overlay-irb-a" },
        "Ethernet20": { "link": "switch2:Ethernet20" }
      }
    },
    "switch2": {
      "interfaces": {
        "Ethernet0": { "link": "switch1:Ethernet0", "service": "transit", "ip": "10.1.0.1/31" },
        "Ethernet4": { "link": "host4:eth0", "service": "local-irb", "ip": "10.100.1.1/24" },
        "Ethernet8": { "link": "host5:eth0", "service": "local-bridge" },
        "Ethernet12": { "link": "host6:eth0", "service": "l2-extend" },
        "Ethernet16": { "link": "host8:eth0", "service": "overlay-irb-b" },
        "Ethernet20": { "link": "switch1:Ethernet20" }
      }
    },
    "host1": { "type": "host", "interfaces": { "eth0": { "link": "switch1:Ethernet4" } } },
    "host2": { "type": "host", "interfaces": { "eth0": { "link": "switch1:Ethernet8" } } },
    "host3": { "type": "host", "interfaces": { "eth0": { "link": "switch1:Ethernet12" } } },
    "host4": { "type": "host", "interfaces": { "eth0": { "link": "switch2:Ethernet4" } } },
    "host5": { "type": "host", "interfaces": { "eth0": { "link": "switch2:Ethernet8" } } },
    "host6": { "type": "host", "interfaces": { "eth0": { "link": "switch2:Ethernet12" } } },
    "host7": { "type": "host", "interfaces": { "eth0": { "link": "switch1:Ethernet16" } } },
    "host8": { "type": "host", "interfaces": { "eth0": { "link": "switch2:Ethernet16" } } }
  },
  "newtlab": {
    "link_port_base": 10000,
    "console_port_base": 12000,
    "ssh_port_base": 13000
  }
}
