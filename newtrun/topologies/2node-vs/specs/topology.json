{
  "version": "1.0",
  "description": "2-node sonic-vs topology: switch1 + switch2 with 6 test hosts — Force10-S6000 stride-4 ports",
  "devices": {
    "switch1": {
      "interfaces": {
        "Ethernet0": { "link": "switch2:Ethernet0" },
        "Ethernet4": { "link": "host1:eth0" },
        "Ethernet8": { "link": "host2:eth0" },
        "Ethernet12": { "link": "host3:eth0" },
        "Ethernet16": { "link": "switch2:Ethernet16" },
        "Ethernet20": { "link": "switch2:Ethernet20" }
      }
    },
    "switch2": {
      "interfaces": {
        "Ethernet0": { "link": "switch1:Ethernet0" },
        "Ethernet4": { "link": "host4:eth0" },
        "Ethernet8": { "link": "host5:eth0" },
        "Ethernet12": { "link": "host6:eth0" },
        "Ethernet16": { "link": "switch1:Ethernet16" },
        "Ethernet20": { "link": "switch1:Ethernet20" }
      }
    },
    "host1": {
      "type": "host",
      "interfaces": {
        "eth0": { "link": "switch1:Ethernet4" }
      }
    },
    "host2": {
      "type": "host",
      "interfaces": {
        "eth0": { "link": "switch1:Ethernet8" }
      }
    },
    "host3": {
      "type": "host",
      "interfaces": {
        "eth0": { "link": "switch1:Ethernet12" }
      }
    },
    "host4": {
      "type": "host",
      "interfaces": {
        "eth0": { "link": "switch2:Ethernet4" }
      }
    },
    "host5": {
      "type": "host",
      "interfaces": {
        "eth0": { "link": "switch2:Ethernet8" }
      }
    },
    "host6": {
      "type": "host",
      "interfaces": {
        "eth0": { "link": "switch2:Ethernet12" }
      }
    }
  },
  "newtlab": {
    "link_port_base": 10000,
    "console_port_base": 12000,
    "ssh_port_base": 13000
  }
}
