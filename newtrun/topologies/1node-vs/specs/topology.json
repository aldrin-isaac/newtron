{
  "version": "1.0",
  "description": "Single SONiC switch for getting started",
  "devices": {
    "switch1": {
      "steps": [
        {
          "url": "/setup-device",
          "params": {
            "fields": {
              "bgp_asn": "65001",
              "docker_routing_config_mode": "unified",
              "frr_mgmt_framework_config": "true",
              "hostname": "switch1",
              "hwsku": "Force10-S6000",
              "type": "LeafRouter"
            }
          }
        }
      ]
    }
  },
  "newtlab": {
    "link_port_base": 10000,
    "console_port_base": 12000,
    "ssh_port_base": 13000
  }
}
