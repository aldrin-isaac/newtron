# Build artifacts
/bin/
/newtron
/newtrun
/newtlab
/newt-server
/newtron-server

# newtrun-generated run reports (CLI default output path)
/.newtrun/

# Claude Code local state (settings, scheduled-task locks, etc.)
.claude/

# IDE / editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

# Private content (managed in separate repo)
/docs/book/

# Per-network audit logs are runtime output, not committed spec (audit.Path)
networks/*/audit/

# Soft-deleted networks are moved here by POST /networks/{id}/delete
# (spec.ArchiveDirName). The archive store is out-of-band recovery only —
# never committed, never served by the API.
networks/archives/
__pycache__/
