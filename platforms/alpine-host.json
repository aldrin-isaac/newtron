{
  "name": "alpine-host",
  "description": "Alpine Linux test host",
  "device_type": "host",
  "port_count": 8,
  "ports": [
    { "name": "eth0", "nic_index": 1 },
    { "name": "eth1", "nic_index": 2 },
    { "name": "eth2", "nic_index": 3 },
    { "name": "eth3", "nic_index": 4 },
    { "name": "eth4", "nic_index": 5 },
    { "name": "eth5", "nic_index": 6 },
    { "name": "eth6", "nic_index": 7 },
    { "name": "eth7", "nic_index": 8 }
  ],
  "vm_image": "~/.newtlab/images/alpine-testhost.qcow2",
  "vm_memory": 256,
  "vm_cpus": 1,
  "vm_nic_driver": "virtio-net-pci",
  "credentials": {
    "user": "root",
    "pass": "root"
  },
  "vm_boot_timeout": 60
}
