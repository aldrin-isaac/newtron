digraph {
    rankdir=TB;
    "\n  Network  \n  (network.json)  \n\n" -> "\n  Zone  \n  (zones/{name}.json)  \n\n" [label="overrides"];
    "\n  Zone  \n  (zones/{name}.json)  \n\n" -> "\n  Node  \n  (nodes/{name}.json)  \n\n" [label="overrides"];
    "\n  Node  \n  (nodes/{name}.json)  \n\n" -> "\n  ResolvedSpecs  \n  (runtime)  \n\n" [label="resolves to"];
}
