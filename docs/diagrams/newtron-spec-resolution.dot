digraph {
    rankdir=TB;
    "\n  Global  \n  (network.json)  \n\n" -> "\n  Zone  \n  (zones.{name})  \n\n" [label="overrides"];
    "\n  Zone  \n  (zones.{name})  \n\n" -> "\n  Node Spec  \n  (nodes/{name}.json)  \n\n" [label="overrides"];
    "\n  Node Spec  \n  (nodes/{name}.json)  \n\n" -> "\n  ResolvedNodeSpec  \n  (runtime)  \n\n" [label="resolves to"];
}
