{
  "version": "1.0",
  "description": "2-node sonic-vs topology: switch1 + switch2 with 6 test hosts — Force10-S6000 stride-4 ports",
  "nodes": {
    "host1": {},
    "host2": {},
    "host3": {},
    "host4": {},
    "host5": {},
    "host6": {},
    "switch1": {
      "steps": [
        {
          "url": "/setup-device",
          "params": {
            "fields": {
              "bgp_asn": "65001",
              "docker_routing_config_mode": "unified",
              "frr_mgmt_framework_config": "true",
              "hostname": "switch1",
              "hwsku": "Force10-S6000",
              "type": "LeafRouter"
            },
            "source_ip": "10.0.0.1"
          }
        },
        {
          "url": "/add-bgp-evpn-peer",
          "params": {
            "asn": 65002,
            "evpn": false,
            "neighbor_ip": "10.0.0.2"
          }
        }
      ],
      "ports": {
        "Ethernet0": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet12": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet16": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet20": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet4": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet8": {
          "admin_status": "up",
          "mtu": 9100
        }
      }
    },
    "switch2": {
      "steps": [
        {
          "url": "/setup-device",
          "params": {
            "fields": {
              "bgp_asn": "65002",
              "docker_routing_config_mode": "unified",
              "frr_mgmt_framework_config": "true",
              "hostname": "switch2",
              "hwsku": "Force10-S6000",
              "type": "LeafRouter"
            },
            "source_ip": "10.0.0.2"
          }
        },
        {
          "url": "/add-bgp-evpn-peer",
          "params": {
            "asn": 65001,
            "evpn": false,
            "neighbor_ip": "10.0.0.1"
          }
        }
      ],
      "ports": {
        "Ethernet0": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet12": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet16": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet20": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet4": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet8": {
          "admin_status": "up",
          "mtu": 9100
        }
      }
    }
  },
  "links": [
    {
      "a": "switch1:Ethernet0",
      "z": "switch2:Ethernet0"
    },
    {
      "a": "switch1:Ethernet4",
      "z": "host1:eth0"
    },
    {
      "a": "switch1:Ethernet8",
      "z": "host2:eth0"
    },
    {
      "a": "switch1:Ethernet12",
      "z": "host3:eth0"
    },
    {
      "a": "switch1:Ethernet16",
      "z": "switch2:Ethernet16"
    },
    {
      "a": "switch1:Ethernet20",
      "z": "switch2:Ethernet20"
    },
    {
      "a": "switch2:Ethernet4",
      "z": "host4:eth0"
    },
    {
      "a": "switch2:Ethernet8",
      "z": "host5:eth0"
    },
    {
      "a": "switch2:Ethernet12",
      "z": "host6:eth0"
    }
  ],
  "newtlab": {
    "link_port_base": 10000,
    "console_port_base": 12000,
    "ssh_port_base": 13000
  }
}
