{
  "version": "1.0",
  "description": "smoke-suite fixture (seed-fixture.mjs)",
  "nodes": {
    "switch1": {
      "steps": [
        {
          "url": "/setup-device",
          "params": {
            "fields": {
              "bgp_asn": "65001",
              "docker_routing_config_mode": "unified",
              "frr_mgmt_framework_config": "true",
              "hostname": "switch1",
              "hwsku": "Force10-S6000",
              "type": "LeafRouter"
            }
          }
        },
        {
          "url": "/interfaces/Ethernet0/apply-service",
          "params": {
            "ip_address": "10.255.255.0/31",
            "peer_as": "65002",
            "service": "TRANSIT"
          }
        },
        {
          "url": "/interfaces/Ethernet4/apply-service",
          "params": {
            "ip_address": "10.255.255.5/31",
            "peer_as": "65003",
            "service": "TRANSIT"
          }
        }
      ],
      "ports": {
        "Ethernet0": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet4": {
          "admin_status": "up",
          "mtu": 9100
        }
      }
    },
