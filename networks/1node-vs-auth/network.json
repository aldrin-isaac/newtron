{
  "version": "1.0",
  "description": "Grant table the 1node-vs-auth suite exercises against an --enforce-authorization newtron-server. Mixes the legacy [\"group\"] shorthand and the L5 typed [{groups, where}] form across every permission family and every where dimension so each layer of the auth arc is exercised end to end.",
  "super_users": [
    "root"
  ],
  "user_groups": {
    "architects": [
      "arch-anna"
    ],
    "device-team": [
      "dev-dora"
    ],
    "iam-team": [
      "iam-ian"
    ],
    "intf-ops": [
      "intf-isaac"
    ],
    "ops": [
      "bob",
      "charlie"
    ],
    "service-team": [
      "svc-sam"
    ],
    "spec-team": [
      "alice",
      "dave"
    ]
  },
  "permissions": {
    "acl.create": [
      "ops"
    ],
    "acl.delete": [
      "ops"
    ],
    "acl.modify": [
      {
        "groups": [
          "ops"
        ]
      },
      {
        "groups": [
          "intf-ops"
        ],
        "where": {
          "interface": "Ethernet0"
        }
      }
    ],
    "audit.read": [
      "iam-team"
    ],
    "auth.read": [
      "iam-team"
    ],
    "bgp.peer": [
      "ops"
    ],
    "device.write": [
      {
        "groups": [
          "spec-team",
          "ops"
        ]
      },
      {
        "groups": [
          "device-team"
        ],
        "where": {
          "device": "switch1"
        }
      },
      {
        "groups": [
          "service-team"
        ],
        "where": {
          "device": "switch1"
        }
      }
    ],
    "evpn.macvpn": [
      "ops"
    ],
    "evpn.peer": [
      "ops"
    ],
    "filter.create": [
      "spec-team"
    ],
    "filter.delete": [
      "spec-team"
    ],
    "interface.modify": [
      "spec-team",
      "ops"
    ],
    "lag.create": [
      "ops"
    ],
    "lag.delete": [
      "ops"
    ],
    "lag.modify": [
      "ops"
    ],
    "qos.create": [
      "spec-team",
      "ops"
    ],
    "qos.delete": [
      "spec-team"
    ],
    "qos.modify": [
      "spec-team",
      "ops"
    ],
    "service.apply": [
      {
        "groups": [
          "spec-team"
        ],
        "where": {
          "resource": "TRANSIT_*"
        }
      },
      {
        "groups": [
          "ops"
        ],
        "where": {
          "resource": "VPN_*"
        }
      },
      {
        "groups": [
          "service-team"
        ],
        "where": {
          "service": "TRANSIT_*"
        }
      }
    ],
    "service.remove": [
      {
        "groups": [
          "spec-team",
          "ops"
        ]
      },
      {
        "groups": [
          "service-team"
        ],
        "where": {
          "service": "TRANSIT_*"
        }
      }
    ],
    "spec.author": [
      {
        "groups": [
          "spec-team"
        ]
      },
      {
        "groups": [
          "architects"
        ],
        "where": {
          "field": "!permissions,!user_groups,!super_users"
        }
      },
      {
        "groups": [
          "iam-team"
        ],
        "where": {
          "field": "permissions,user_groups,super_users"
        }
      }
    ],
    "vlan.create": [
      "ops"
    ],
    "vlan.delete": [
      "ops"
    ],
    "vlan.modify": [
      "ops"
    ],
    "vrf.bind": [
      "ops"
    ],
    "vrf.create": [
      {
        "groups": [
          "ops"
        ]
      },
      {
        "groups": [
          "service-team"
        ],
        "where": {
          "service": "TRANSIT_*"
        }
      }
    ],
    "vrf.delete": [
      "ops"
    ],
    "vrf.route": [
      "ops"
    ]
  },
  "services": {
    "TRANSIT_1": {
      "description": "Transit peering service — used by the L5 resource-scope scenario",
      "service_type": "routed",
      "routing": {
        "protocol": "bgp",
        "peer_as": "request"
      }
    }
  }
}
