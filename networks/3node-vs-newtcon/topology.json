          }
        }
      ],
      "ports": {
        "Ethernet0": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet1": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet4": {
          "admin_status": "up",
          "mtu": 9100
        }
      }
    }
  },
  "links": [
    {
      "a": "switch2:Ethernet4",
      "z": "switch3:Ethernet0"
    },
    {
      "a": "switch3:Ethernet4",
