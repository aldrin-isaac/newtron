{
  "version": "1.0",
  "description": "3-node vs network for newtcon testing (RECONSTRUCTED from audit logs 2026-06-28 after accidental deletion)",
  "nodes": {
    "host1": {},
    "host2": {},
    "host3": {},
    "switch1": {
      "steps": [
        {
          "url": "/setup-device"
        },
        {
          "url": "/create-acl",
          "params": {
            "description": "Ingress filter for EVPNIRB",
            "name": "FILTER1_IN_8C5EA5AD",
            "ports": "Ethernet2",
            "stage": "ingress",
            "type": "L3"
          }
        },
        {
          "url": "/create-acl",
          "params": {
            "description": "Egress filter for EVPNIRB",
            "name": "FILTER1_OUT_8C5EA5AD",
            "ports": "Ethernet2",
            "stage": "egress",
            "type": "L3"
          }
        },
        {
          "url": "/interfaces/Ethernet0/apply-service",
          "params": {
            "ip_address": "10.255.255.0/31",
            "peer_as": "64513",
            "service": "TRANSIT"
          }
        },
        {
          "url": "/interfaces/Ethernet1/configure-interface",
          "params": {
            "ip": "10.10.1.1/24"
          }
        },
        {
          "url": "/interfaces/Ethernet4/apply-service",
          "params": {
            "ip_address": "10.255.255.5/31",
            "peer_as": "64514",
            "service": "TRANSIT"
          }
        },
        {
          "url": "/create-vlan",
          "params": {
            "vlan_id": "100"
          }
        },
        {
          "url": "/create-vrf",
          "params": {
            "name": "Vrf_EVPNIRB"
          }
        },
        {
          "url": "/interfaces/Ethernet2/add-trunk-vlan",
          "params": {
            "tagged": "true",
            "vlan_id": "100"
          }
        },
        {
          "url": "/bind-macvpn",
          "params": {
            "macvpn": "MACVPN",
            "vlan_id": "100",
            "vni": "10100"
          }
        },
        {
          "url": "/configure-irb",
          "params": {
            "anycast_mac": "01:01:01:01:01:01",
            "ip_address": "10.100.0.1/24",
            "vlan_id": "100",
            "vrf": "Vrf_EVPNIRB"
          }
        },
        {
          "url": "/bind-ipvpn",
          "params": {
            "ipvpn": "IPVPN",
            "l3vni": "10001",
            "l3vni_vlan": "0",
            "route_targets": "65001:300",
            "vrf_name": "Vrf_EVPNIRB"
          }
        },
        {
          "url": "/interfaces/Vlan100/apply-service",
          "params": {
            "service": "EVPNIRB",
            "vlan_id": "100"
          }
        }
      ],
      "ports": {
        "Ethernet0": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet1": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet4": {
          "admin_status": "up",
          "mtu": 9100
        }
      }
    },
    "switch2": {
      "steps": [
        {
          "url": "/setup-device",
          "params": {
            "fields": {
              "bgp_asn": "64513",
              "docker_routing_config_mode": "unified",
              "frr_mgmt_framework_config": "true",
              "hostname": "switch2",
              "hwsku": "cisco-p200-32x100-vs",
              "type": "LeafRouter"
            }
          }
        },
        {
          "url": "/interfaces/Ethernet0/apply-service",
          "params": {
