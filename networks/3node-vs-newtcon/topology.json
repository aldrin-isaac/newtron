          }
        },
        {
          "url": "/interfaces/Ethernet4/apply-service",
          "params": {
            "ip_address": "10.255.255.4/31",
            "peer_as": "64512",
            "service": "TRANSIT"
          }
        },
        {
          "url": "/interfaces/Ethernet1/configure-interface",
