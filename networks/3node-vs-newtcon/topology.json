            "peer_as": "64514",
            "service": "TRANSIT"
          }
        },
        {
          "url": "/interfaces/Ethernet1/configure-interface",
          "params": {
            "ip": "10.10.2.1/24"
          }
        }
      ],
      "ports": {
        "Ethernet0": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet1": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet4": {
          "admin_status": "up",
          "mtu": 9100
        }
      }
    },
    "switch3": {
      "steps": [
        {
          "url": "/setup-device",
          "params": {
            "fields": {
              "bgp_asn": "64514",
              "docker_routing_config_mode": "unified",
              "frr_mgmt_framework_config": "true",
              "hostname": "switch3",
              "hwsku": "cisco-p200-32x100-vs",
