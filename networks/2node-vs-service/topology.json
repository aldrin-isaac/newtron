{
 "version": "1.0",
 "description": "2-node sonic-vs service topology: switch1 + switch2 with 8 test hosts — Force10-S6000 stride-4 ports",
 "nodes": {
  "switch1": {
   "steps": [
    {
     "url": "/setup-device",
     "params": {
      "fields": {
       "hostname": "switch1",
       "bgp_asn": "65001",
       "type": "LeafRouter",
       "hwsku": "Force10-S6000",
       "docker_routing_config_mode": "unified",
       "frr_mgmt_framework_config": "true"
      },
      "source_ip": "10.0.0.1"
     }
    },
    {
     "url": "/interfaces/Ethernet0/apply-service",
     "params": {
      "service": "transit",
      "ip_address": "10.1.0.0/31",
      "peer_as": 65002
     }
    },
    {
     "url": "/create-vlan",
     "params": {
      "vlan_id": 100
     }
    },
    {
     "url": "/interfaces/Ethernet4/configure-interface",
     "params": {
      "vlan_id": 100,
      "tagged": true
     }
    },
    {
     "url": "/interfaces/Ethernet4/apply-service",
     "params": {
      "service": "local-irb",
      "ip_address": "10.100.1.1/24"
     }
    },
    {
     "url": "/create-vlan",
     "params": {
      "vlan_id": 200
     }
    },
    {
     "url": "/interfaces/Ethernet8/configure-interface",
     "params": {
      "vlan_id": 200,
      "tagged": false
     }
    },
    {
     "url": "/interfaces/Ethernet8/apply-service",
     "params": {
      "service": "local-bridge"
     }
    },
    {
     "url": "/create-vlan",
     "params": {
      "vlan_id": 300
     }
    },
    {
     "url": "/bind-macvpn",
     "params": {
      "vlan_id": 300,
      "macvpn": "EXTEND_VLAN300"
     }
    },
    {
     "url": "/interfaces/Ethernet12/configure-interface",
     "params": {
      "vlan_id": 300,
      "tagged": false
     }
    },
    {
     "url": "/interfaces/Ethernet12/apply-service",
     "params": {
      "service": "l2-extend"
     }
    },
    {
     "url": "/create-vlan",
     "params": {
      "vlan_id": 400
     }
    },
    {
     "url": "/bind-macvpn",
     "params": {
      "vlan_id": 400,
      "macvpn": "IRB_VLAN400"
     }
    },
    {
     "url": "/interfaces/Ethernet16/configure-interface",
     "params": {
      "vlan_id": 400,
      "tagged": true
     }
    },
    {
     "url": "/interfaces/Ethernet16/apply-service",
     "params": {
      "service": "overlay-irb-a"
     }
    }
   ],
   "ports": {
    "Ethernet0": {
     "admin_status": "up",
     "mtu": 9100
    },
    "Ethernet4": {
     "admin_status": "up",
     "mtu": 9100
    },
    "Ethernet8": {
     "admin_status": "up",
     "mtu": 9100
    },
    "Ethernet12": {
     "admin_status": "up",
     "mtu": 9100
    },
    "Ethernet16": {
     "admin_status": "up",
     "mtu": 9100
    },
    "Ethernet20": {
     "admin_status": "up",
     "mtu": 9100
    }
   }
  },
  "switch2": {
