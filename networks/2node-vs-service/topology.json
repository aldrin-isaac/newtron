          "params": {
            "service": "rtd",
            "ip_address": "10.1.0.1/31",
            "peer_as": 65001
          }
        },
        {
          "url": "/create-vlan",
          "params": {
            "vlan_id": 100
          }
        },
        {
          "url": "/interfaces/Ethernet4/configure-interface",
          "params": {
            "vlan_id": 100,
