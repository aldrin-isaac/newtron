          }
        },
        {
          "url": "/interfaces/Vlan100/apply-service",
          "params": {
            "service": "irb"
          }
        },
        {
          "url": "/create-vlan",
          "params": {
            "vlan_id": 200
          }
        },
        {
          "url": "/interfaces/Ethernet8/configure-interface",
          "params": {
            "vlan_id": 200,
            "tagged": false
          }
        },
        {
          "url": "/interfaces/Ethernet8/apply-service",
          "params": {
            "service": "brd"
          }
        },
        {
          "url": "/create-vlan",
          "params": {
            "vlan_id": 300
          }
        },
        {
          "url": "/bind-macvpn",
          "params": {
            "vlan_id": 300,
            "macvpn": "EXTEND_VLAN300"
          }
        },
        {
          "url": "/interfaces/Ethernet12/configure-interface",
          "params": {
            "vlan_id": 300,
            "tagged": false
          }
        },
        {
          "url": "/interfaces/Ethernet12/apply-service",
          "params": {
            "service": "ebrd"
          }
        },
        {
          "url": "/create-vlan",
          "params": {
            "vlan_id": 401
          }
        },
        {
          "url": "/bind-macvpn",
          "params": {
            "vlan_id": 401,
            "macvpn": "IRB_VLAN401"
          }
        },
        {
          "url": "/interfaces/Ethernet16/configure-interface",
          "params": {
            "vlan_id": 401,
