            "anycast_mac": "00:00:00:01:04:00"
          }
        },
        {
          "url": "/interfaces/Vlan401/apply-service",
          "params": {
            "service": "eirb2"
          }
        }
      ],
      "ports": {
        "Ethernet0": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet4": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet8": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet12": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet16": {
          "admin_status": "up",
          "mtu": 9100
        },
        "Ethernet20": {
          "admin_status": "up",
          "mtu": 9100
        }
      }
    },
    "host1": {},
    "host2": {},
    "host3": {},
    "host4": {},
    "host5": {},
    "host6": {},
    "host7": {},
    "host8": {}
  },
  "links": [
    {
      "a": "switch1:Ethernet0",
      "z": "switch2:Ethernet0"
    },
    {
      "a": "switch1:Ethernet4",
      "z": "host1:eth0"
    },
    {
      "a": "switch1:Ethernet8",
      "z": "host2:eth0"
    },
    {
      "a": "switch1:Ethernet12",
      "z": "host3:eth0"
    },
    {
      "a": "switch1:Ethernet16",
      "z": "host7:eth0"
    },
    {
      "a": "switch1:Ethernet20",
      "z": "switch2:Ethernet20"
    },
    {
      "a": "switch2:Ethernet4",
      "z": "host4:eth0"
    },
    {
      "a": "switch2:Ethernet8",
